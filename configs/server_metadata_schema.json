{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/server_metadata_schema.json",
  "title": "Phone Server Metadata",
  "description": "Schema for capturing phone-side llama.cpp server metadata for benchmark reproducibility",
  "type": "object",
  "required": ["schema_version", "capture_timestamp", "llama_cpp", "device", "model"],
  "properties": {
    "schema_version": {
      "type": "string",
      "description": "Version of this metadata schema",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "capture_timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp when metadata was captured"
    },
    "llama_cpp": {
      "type": "object",
      "description": "llama.cpp build and version information",
      "required": ["commit_hash"],
      "properties": {
        "directory": {
          "type": "string",
          "description": "Path to llama.cpp installation"
        },
        "commit_hash": {
          "type": "string",
          "description": "Full 40-character git commit SHA of llama.cpp build (MANDATORY)",
          "pattern": "^[a-f0-9]{40}$"
        },
        "commit_date": {
          "type": "string",
          "description": "ISO 8601 date of the commit"
        },
        "dirty": {
          "type": ["boolean", "string"],
          "description": "Whether the build has uncommitted changes"
        },
        "build_flags": {
          "type": "string",
          "description": "CMake build flags used (e.g., '-DGGML_OPENCL=ON')"
        }
      }
    },
    "model": {
      "type": "object",
      "description": "Model file information (MANDATORY for reproducibility)",
      "required": ["sha256"],
      "properties": {
        "name": {
          "type": "string",
          "description": "Full HuggingFace-style model identifier"
        },
        "filename": {
          "type": "string",
          "description": "Exact GGUF filename"
        },
        "sha256": {
          "type": "string",
          "description": "SHA-256 hash of model file (MANDATORY, 64 hex characters)",
          "pattern": "^[a-f0-9]{64}$"
        },
        "parameter_count": {
          "type": "string",
          "description": "Model parameter count (e.g., '1B', '3B', '8B')"
        },
        "quantization": {
          "type": "string",
          "description": "Quantization format (must be Q4_0 for core comparisons)",
          "enum": ["Q4_0", "Q4_1", "Q5_0", "Q5_1", "Q8_0"]
        }
      }
    },
    "device": {
      "type": "object",
      "description": "Device hardware and software information",
      "properties": {
        "android": {
          "type": "object",
          "description": "Android OS information",
          "properties": {
            "sdk_version": {
              "type": "string",
              "description": "Android SDK version"
            },
            "release": {
              "type": "string",
              "description": "Android version release"
            },
            "device": {
              "type": "string",
              "description": "Device codename"
            },
            "model": {
              "type": "string",
              "description": "Device model name"
            }
          }
        },
        "termux_version": {
          "type": "string",
          "description": "Termux application version"
        },
        "cpu": {
          "type": "object",
          "description": "CPU information",
          "properties": {
            "model": {
              "type": "string",
              "description": "CPU model name or hardware identifier"
            },
            "cores": {
              "type": ["string", "integer"],
              "description": "Number of CPU cores"
            }
          }
        },
        "memory": {
          "type": "object",
          "description": "Memory information",
          "properties": {
            "total_kb": {
              "type": ["string", "integer"],
              "description": "Total memory in kilobytes"
            },
            "available_kb": {
              "type": ["string", "integer"],
              "description": "Available memory in kilobytes"
            }
          }
        }
      }
    },
    "environment": {
      "type": "object",
      "description": "Runtime environment state captured outside the active inference window",
      "properties": {
        "capture_phase": {
          "type": "string",
          "enum": ["pre_run", "post_run", "snapshot"],
          "description": "Whether this metadata snapshot was captured before a run, after a run, or as a standalone snapshot"
        },
        "device_temperature_c": {
          "type": ["number", "string", "null"],
          "description": "Single device temperature snapshot in Celsius, usually battery temperature when readable"
        },
        "start_temperature_c": {
          "type": ["number", "string", "null"],
          "description": "Pre-run device temperature snapshot in Celsius; optional and never inferred"
        },
        "end_temperature_c": {
          "type": ["number", "string", "null"],
          "description": "Post-run device temperature snapshot in Celsius; optional and never inferred"
        },
        "temperature_source": {
          "type": "string",
          "description": "Source for device temperature fields, e.g. sysfs_power_supply_battery_temp, dumpsys_battery_temperature, or unavailable"
        },
        "battery_level_percent": {
          "type": ["string", "integer"],
          "description": "Single battery charge percentage snapshot"
        },
        "start_battery_level_percent": {
          "type": ["string", "integer", "null"],
          "description": "Pre-run battery charge percentage snapshot"
        },
        "end_battery_level_percent": {
          "type": ["string", "integer", "null"],
          "description": "Post-run battery charge percentage snapshot"
        },
        "battery_status": {
          "type": "string",
          "description": "Battery charging status (Charging, Discharging, Full, etc.)"
        },
        "thermal_zones": {
          "type": "array",
          "description": "Thermal zone readings",
          "items": {
            "type": "object",
            "properties": {
              "zone": {
                "type": "string",
                "description": "Thermal zone identifier"
              },
              "type": {
                "type": "string",
                "description": "Thermal zone type"
              },
              "temp_millicelsius": {
                "type": ["string", "integer"],
                "description": "Temperature in millicelsius"
              }
            }
          }
        }
      }
    },
    "notes": {
      "type": "object",
      "description": "Manual observations and notes",
      "properties": {
        "background_apps_minimized": {
          "type": ["boolean", "null"],
          "description": "Whether background apps were minimized before capture"
        },
        "manual_observations": {
          "type": ["string", "null"],
          "description": "Any manual observations about device state"
        },
        "known_anomalies": {
          "type": ["string", "null"],
          "description": "Known anomalies that may affect interpretation, such as USB reconnects, notifications, or manual intervention"
        }
      }
    },
    "server_config": {
      "type": "object",
      "description": "Server launch configuration",
      "properties": {
        "model_path": {
          "type": "string",
          "description": "Path to the GGUF model file"
        },
        "context_length": {
          "type": "integer",
          "description": "Context length (-c flag), must be 2048 for core benchmarks"
        },
        "gpu_layers": {
          "type": "integer",
          "description": "GPU offload layers (-ngl flag)"
        },
        "port": {
          "type": "integer",
          "description": "Server port"
        },
        "host": {
          "type": "string",
          "description": "Server bind address"
        },
        "backend": {
          "type": "string",
          "enum": ["cpu", "opencl", "npu_experimental"],
          "description": "Accelerator backend used"
        },
        "launch_args": {
          "type": "string",
          "description": "Full server launch command arguments"
        }
      }
    }
  }
}
